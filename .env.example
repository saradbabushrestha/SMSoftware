# ─── Database ──────────────────────────────────────────────────────────────
# Local Docker Postgres (see docker-compose.yml) on host port 5437.
DATABASE_URL="postgresql://sms:sms_dev_password@localhost:5437/school_management?schema=public"

# ─── Auth / JWT ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 48
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
