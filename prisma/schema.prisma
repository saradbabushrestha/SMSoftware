// School Management System — core schema (Foundation milestone)
// Multi-tenant (per-school isolation), RBAC, and core academic entities.
// Conventions: every table has createdAt/updatedAt; tenant data is soft-deleted
// via deletedAt; foreign keys are indexed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  PRINCIPAL
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

enum AcademicYearStatus {
  UPCOMING
  ACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  PROMOTED
  TRANSFERRED
  GRADUATED
  SUSPENDED
  WITHDRAWN
  ALUMNI
}

enum GuardianRelation {
  FATHER
  MOTHER
  GRANDPARENT
  SIBLING
  UNCLE
  AUNT
  LEGAL_GUARDIAN
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum ExamType {
  UNIT_TEST
  MIDTERM
  FINAL
  PRACTICAL
}

enum FeeCategory {
  TUITION
  EXAMINATION
  TRANSPORT
  HOSTEL
  LIBRARY
  OTHER
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

// Nepal payment gateways (+ manual cash/bank). No international gateways.
enum PaymentMethod {
  ESEWA
  KHALTI
  FONEPAY
  CASH
  BANK
}

enum LoanStatus {
  BORROWED
  RETURNED
}

enum EventType {
  GENERAL
  SPORTS
  COMPETITION
  WORKSHOP
  MEETING
  HOLIDAY
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
}

enum HostelType {
  BOYS
  GIRLS
  MIXED
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum PayrollStatus {
  DRAFT
  PAID
}

enum LedgerType {
  INCOME
  EXPENSE
}

enum AnnouncementAudience {
  ALL
  STAFF
  STUDENTS
  PARENTS
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────────────────────

model School {
  id       String  @id @default(cuid())
  name     String
  code     String  @unique // short slug used in URLs / IDs, e.g. "GHS"
  email    String?
  phone    String?
  address  String?
  city     String?
  country  String? @default("Nepal")
  logoUrl  String?
  timezone String  @default("Asia/Kathmandu")
  isActive Boolean @default(true)

  users         User[]
  academicYears AcademicYear[]
  classes       SchoolClass[]
  subjects      Subject[]
  students      Student[]
  teachers      Teacher[]
  guardians     Guardian[]
  enrollments   Enrollment[]
  auditLogs     AuditLog[]
  attendance    Attendance[]
  exams         Exam[]
  invoices      Invoice[]
  payments      Payment[]
  paymentTransactions PaymentTransaction[]
  books         Book[]
  bookLoans     BookLoan[]
  events        Event[]
  assignments   Assignment[]
  routes        Route[]
  rooms         Room[]
  timetable     TimetableEntry[]
  payrollRecords PayrollRecord[]
  ledgerEntries  LedgerEntry[]
  announcements  Announcement[]
  messages       Message[]
  teacherEvaluations TeacherEvaluation[]
  subscription   Subscription?
  reportSubmissions ReportSubmission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive])
  @@map("schools")
}

enum SubscriptionPlan {
  TRIAL
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Subscription {
  id          String             @id @default(cuid())
  schoolId    String             @unique
  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan   @default(TRIAL)
  status      SubscriptionStatus @default(TRIALING)
  seats       Int                @default(50) // max user accounts allowed
  priceNpr    Int                @default(0) // monthly price, NPR
  startedAt   DateTime           @default(now())
  renewsAt    DateTime?
  note        String?
  updatedById String? // super admin who last changed it (no FK)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("subscriptions")
}

enum ReportStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

// A report a staff member submits for a principal to approve / reject.
model ReportSubmission {
  id            String       @id @default(cuid())
  schoolId      String
  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title         String
  category      String // e.g. "Academic", "Attendance", "Finance", "Other"
  period        String?
  summary       String
  status        ReportStatus @default(SUBMITTED)
  submittedById String? // author (no FK)
  reviewedById  String? // approver (no FK)
  reviewNote    String?
  reviewedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([status])
  @@map("report_submissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & Access (RBAC)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole
  status       UserStatus @default(ACTIVE)

  firstName String
  lastName  String
  phone     String?
  avatarUrl String?

  // null for platform-level SUPER_ADMIN; set for school-scoped users
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  lastLoginAt   DateTime?
  emailVerified DateTime?

  refreshTokens RefreshToken[]
  permissions   UserPermission[]
  auditLogs     AuditLog[]
  markedAttendance Attendance[] @relation("MarkedAttendance")
  recordedPayments Payment[]    @relation("RecordedPayments")
  bookLoans        BookLoan[]   @relation("BookLoans")
  createdEvents    Event[]      @relation("CreatedEvents")
  eventRegistrations EventRegistration[] @relation("EventRegistrations")
  createdAssignments Assignment[] @relation("CreatedAssignments")
  gradedSubmissions  Submission[] @relation("GradedSubmissions")
  sentMessages       Message[]    @relation("MessageSender")
  receivedMessages   Message[]    @relation("MessageRecipient")

  // Profile back-relations (a user is at most one of these)
  teacherProfile  Teacher?
  studentProfile  Student?
  guardianProfile Guardian?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // sha-256 of the opaque token
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Permission catalog (data-driven mirror of the code-level permission matrix).
model Permission {
  id          String  @id @default(cuid())
  key         String  @unique // e.g. "student:create"
  description String?

  users UserPermission[]

  createdAt DateTime @default(now())

  @@map("permissions")
}

// Per-user permission grants (overrides on top of role defaults).
model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granted      Boolean    @default(true) // false = explicit deny

  createdAt DateTime @default(now())

  @@unique([userId, permissionId])
  @@index([permissionId])
  @@map("user_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Academic structure
// ─────────────────────────────────────────────────────────────────────────────

model AcademicYear {
  id        String             @id @default(cuid())
  schoolId  String
  school    School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String // e.g. "2024-2025"
  startDate DateTime
  endDate   DateTime
  status    AcademicYearStatus @default(UPCOMING)

  enrollments Enrollment[]
  exams       Exam[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("academic_years")
}

model SchoolClass {
  id       String  @id @default(cuid())
  schoolId String
  school   School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name     String // e.g. "Grade 10"
  code     String // e.g. "G10"
  stream   String? // e.g. "Science", "Management" (higher grades)
  capacity Int     @default(40)

  sections Section[]
  subjects Subject[]
  exams    Exam[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("classes")
}

model Section {
  id             String      @id @default(cuid())
  classId        String
  class          SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  name           String // e.g. "A"
  capacity       Int         @default(40)
  classTeacherId String?
  classTeacher   Teacher?    @relation("SectionClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)

  enrollments Enrollment[]
  attendance  Attendance[]
  assignments Assignment[]
  timetable   TimetableEntry[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([classId, name])
  @@index([classId])
  @@index([classTeacherId])
  @@map("sections")
}

model Subject {
  id       String       @id @default(cuid())
  schoolId String
  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId  String?
  class    SchoolClass? @relation(fields: [classId], references: [id], onDelete: SetNull)
  name     String
  code     String
  credits  Int          @default(1)

  teachers    Teacher[]        @relation("TeacherSubjects")
  examResults ExamResult[]
  assignments Assignment[]
  timetableEntries TimetableEntry[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([classId])
  @@map("subjects")
}

// ─────────────────────────────────────────────────────────────────────────────
// People: Teachers, Students, Guardians
// ─────────────────────────────────────────────────────────────────────────────

model Teacher {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeId    String
  qualification String?
  experienceYrs Int       @default(0)
  joinedOn      DateTime?

  subjects    Subject[] @relation("TeacherSubjects")
  sectionsLed Section[] @relation("SectionClassTeacher")
  timetableEntries TimetableEntry[]
  payrollRecords   PayrollRecord[]
  evaluations      TeacherEvaluation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, employeeId])
  @@index([schoolId])
  @@map("teachers")
}

model TeacherEvaluation {
  id          String  @id @default(cuid())
  schoolId    String
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  evaluatorId String? // user id of the evaluator (no FK constraint)
  period      String // e.g. "2024 — Term 1"

  // Dimension scores, each 1–5.
  teaching      Int
  classroom     Int
  collaboration Int
  punctuality   Int
  comment       String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([teacherId])
  @@map("teacher_evaluations")
}

model Student {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  admissionNumber String
  rollNumber      String?
  dateOfBirth     DateTime?
  gender          Gender           @default(UNDISCLOSED)
  bloodGroup      BloodGroup       @default(UNKNOWN)
  nationality     String?          @default("Nepali")
  address         String?
  admittedOn      DateTime?
  status          EnrollmentStatus @default(ACTIVE)

  guardians   StudentGuardian[]
  enrollments Enrollment[]
  attendance  Attendance[]
  examResults ExamResult[]
  invoices    Invoice[]
  submissions Submission[]
  transportAssignments TransportAssignment[]
  roomAssignments RoomAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([status])
  @@map("students")
}

model Guardian {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userId   String @unique
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  occupation String?
  address    String?

  students StudentGuardian[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@map("guardians")
}

// Many-to-many: a student may have multiple guardians and vice-versa.
model StudentGuardian {
  id         String           @id @default(cuid())
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardianId String
  guardian   Guardian         @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  relation   GuardianRelation @default(OTHER)
  isPrimary  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@unique([studentId, guardianId])
  @@index([guardianId])
  @@map("student_guardians")
}

// A student's placement in a section for a given academic year (history-friendly).
model Enrollment {
  id             String           @id @default(cuid())
  schoolId       String
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicYearId String
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  rollNumber     String?
  status         EnrollmentStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([studentId, academicYearId])
  @@index([schoolId])
  @@index([sectionId])
  @@index([academicYearId])
  @@map("enrollments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// Examinations & grading
// ─────────────────────────────────────────────────────────────────────────────

model Exam {
  id             String        @id @default(cuid())
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId        String
  class          SchoolClass   @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  name           String // e.g. "Mid-Term 2024"
  type           ExamType      @default(MIDTERM)
  maxMarks       Int           @default(100)
  examDate       DateTime?     @db.Date
  published      Boolean       @default(false) // visible to students/parents when true

  results ExamResult[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([classId])
  @@map("exams")
}

model ExamResult {
  id            String  @id @default(cuid())
  examId        String
  exam          Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  marksObtained Float
  maxMarks      Int     @default(100)
  remark        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@map("exam_results")
}

// ─────────────────────────────────────────────────────────────────────────────
// Finance: invoices & payments
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id        String        @id @default(cuid())
  schoolId  String
  school    School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  category  FeeCategory   @default(TUITION)
  title     String
  amount    Float
  dueDate   DateTime?     @db.Date
  status    InvoiceStatus @default(PENDING)
  note      String?

  payments Payment[]
  transactions PaymentTransaction[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@map("invoices")
}

model Payment {
  id           String        @id @default(cuid())
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceId    String
  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount       Float
  method       PaymentMethod @default(ESEWA)
  reference    String? // gateway transaction id / receipt no.
  paidAt       DateTime      @default(now())
  recordedById String?
  recordedBy   User?         @relation("RecordedPayments", fields: [recordedById], references: [id], onDelete: SetNull)
  transaction  PaymentTransaction?

  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([invoiceId])
  @@index([paidAt])
  @@map("payments")
}

enum PaymentGateway {
  ESEWA
  KHALTI
  FONEPAY
}

enum TxnStatus {
  PENDING
  COMPLETED
  FAILED
}

// A gateway checkout attempt: created PENDING on initiate, confirmed on the
// verified callback (which then creates the linked Payment). Decouples the
// async redirect/verify flow from the immutable Payment ledger.
model PaymentTransaction {
  id            String         @id @default(cuid())
  schoolId      String
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoiceId     String
  invoice       Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  gateway       PaymentGateway
  amount        Float
  reference     String         @unique // eSewa transaction_uuid / Khalti pidx
  status        TxnStatus      @default(PENDING)
  gatewayRef    String? // gateway's own txn id once completed
  initiatedById String?
  paymentId     String?        @unique
  payment       Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([invoiceId])
  @@index([status])
  @@map("payment_transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Library
// ─────────────────────────────────────────────────────────────────────────────

model Book {
  id              String  @id @default(cuid())
  schoolId        String
  school          School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title           String
  author          String
  isbn            String?
  category        String?
  totalCopies     Int     @default(1)
  availableCopies Int     @default(1)

  loans BookLoan[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@map("books")
}

model BookLoan {
  id         String     @id @default(cuid())
  schoolId   String
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  bookId     String
  book       Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  memberId   String
  member     User       @relation("BookLoans", fields: [memberId], references: [id], onDelete: Cascade)
  borrowedAt DateTime   @default(now())
  dueDate    DateTime   @db.Date
  returnedAt DateTime?
  status     LoanStatus @default(BORROWED)

  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([bookId])
  @@index([memberId])
  @@index([status])
  @@map("book_loans")
}

// ─────────────────────────────────────────────────────────────────────────────
// Timetable
// ─────────────────────────────────────────────────────────────────────────────

model TimetableEntry {
  id        String  @id @default(cuid())
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  day       Weekday
  startTime String // "HH:mm" (24h)
  endTime   String // "HH:mm" (24h)
  room      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([sectionId, day])
  @@index([teacherId, day])
  @@map("timetable_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// Payroll & accounting
// ─────────────────────────────────────────────────────────────────────────────

model PayrollRecord {
  id           String        @id @default(cuid())
  schoolId     String
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  month        String // "YYYY-MM"
  basicSalary  Float
  allowances   Float         @default(0)
  deductions   Float         @default(0)
  tax          Float         @default(0)
  netPay       Float
  status       PayrollStatus @default(DRAFT)
  paidAt       DateTime?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One payslip per teacher per month.
  @@unique([teacherId, month])
  @@index([schoolId, month])
  @@map("payroll_records")
}

model LedgerEntry {
  id          String     @id @default(cuid())
  schoolId    String
  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type        LedgerType
  category    String
  description String?
  amount      Float
  date        DateTime   @db.Date
  createdById String? // user id of the recorder (no FK constraint)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([type])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// Communication — announcements / notice board
// ─────────────────────────────────────────────────────────────────────────────

model Announcement {
  id          String               @id @default(cuid())
  schoolId    String
  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title       String
  body        String
  audience    AnnouncementAudience @default(ALL)
  pinned      Boolean              @default(false)
  publishedAt DateTime             @default(now())
  expiresAt   DateTime?
  authorId    String? // user id of the author (no FK constraint)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([audience])
  @@index([pinned])
  @@map("announcements")
}

model Message {
  id          String    @id @default(cuid())
  schoolId    String?
  school      School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User      @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  subject     String
  body        String
  readAt      DateTime?

  // Per-side soft delete: removing a message from your inbox/sent box doesn't
  // remove it from the other participant's view.
  senderDeletedAt    DateTime?
  recipientDeletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientId, recipientDeletedAt])
  @@index([senderId, senderDeletedAt])
  @@index([schoolId])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// Hostel
// ─────────────────────────────────────────────────────────────────────────────

model Room {
  id         String     @id @default(cuid())
  schoolId   String
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  block      String // e.g. "Block A"
  number     String // e.g. "101"
  gender     HostelType @default(MIXED)
  capacity   Int        @default(2) // beds
  wardenName String?
  notes      String?

  assignments RoomAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@map("rooms")
}

model RoomAssignment {
  id        String  @id @default(cuid())
  roomId    String
  room      Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  bedNumber String?

  createdAt DateTime @default(now())

  // One hostel room per student.
  @@unique([studentId])
  @@index([roomId])
  @@map("room_assignments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Transport
// ─────────────────────────────────────────────────────────────────────────────

model Route {
  id            String  @id @default(cuid())
  schoolId      String
  school        School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  vehicleNumber String?
  driverName    String?
  driverPhone   String?
  capacity      Int     @default(0) // 0 = unlimited
  fare          Float   @default(0) // monthly fare (NPR)

  assignments TransportAssignment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@map("routes")
}

model TransportAssignment {
  id        String  @id @default(cuid())
  routeId   String
  route     Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  stop      String?

  createdAt DateTime @default(now())

  // One transport route per student.
  @@unique([studentId])
  @@index([routeId])
  @@map("transport_assignments")
}

// ─────────────────────────────────────────────────────────────────────────────
// Assignments
// ─────────────────────────────────────────────────────────────────────────────

model Assignment {
  id          String      @id @default(cuid())
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sectionId   String
  section     Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subjectId   String
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  maxPoints   Int         @default(100)
  createdById String?
  createdBy   User?       @relation("CreatedAssignments", fields: [createdById], references: [id], onDelete: SetNull)

  submissions Submission[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([sectionId])
  @@map("assignments")
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content      String
  status       SubmissionStatus @default(SUBMITTED)
  grade        Float?
  feedback     String?
  submittedAt  DateTime         @default(now())
  gradedAt     DateTime?
  gradedById   String?
  gradedBy     User?            @relation("GradedSubmissions", fields: [gradedById], references: [id], onDelete: SetNull)

  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@map("submissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Events
// ─────────────────────────────────────────────────────────────────────────────

model Event {
  id               String    @id @default(cuid())
  schoolId         String
  school           School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  type             EventType @default(GENERAL)
  startsAt         DateTime
  endsAt           DateTime?
  location         String?
  capacity         Int       @default(0) // 0 = unlimited
  registrationOpen Boolean   @default(true)
  createdById      String?
  createdBy        User?     @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: SetNull)

  registrations EventRegistration[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([schoolId])
  @@index([startsAt])
  @@map("events")
}

model EventRegistration {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation("EventRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_registrations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Attendance
// ─────────────────────────────────────────────────────────────────────────────

model Attendance {
  id         String           @id @default(cuid())
  schoolId   String
  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sectionId  String
  section    Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       DateTime         @db.Date
  status     AttendanceStatus @default(PRESENT)
  remark     String?
  markedById String?
  markedBy   User?            @relation("MarkedAttendance", fields: [markedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One record per student per day.
  @@unique([studentId, date])
  @@index([schoolId])
  @@index([sectionId, date])
  @@index([date])
  @@map("attendance")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id       String  @id @default(cuid())
  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  userId   String?
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     String // e.g. "auth.login", "student.create"
  entityType String? // e.g. "Student"
  entityId   String?
  metadata   Json?
  ip         String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
